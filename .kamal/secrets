# Fetch all secrets from 1Password
SECRETS=$(kamal secrets fetch --adapter 1password --account zamsua --from "QuillCV/Kamal Production" KAMAL_REGISTRY_PASSWORD DB_PASSWORD SESSION_SECRET ENCRYPTION_KEY JWT_SECRET ANTHROPIC_API_KEY GOOGLE_API_KEY STRIPE_SECRET_KEY STRIPE_WEBHOOK_SECRET)

DB_PASSWORD=$(kamal secrets extract DB_PASSWORD $SECRETS)
SESSION_SECRET=$(kamal secrets extract SESSION_SECRET $SECRETS)
ENCRYPTION_KEY=$(kamal secrets extract ENCRYPTION_KEY $SECRETS)
JWT_SECRET=$(kamal secrets extract JWT_SECRET $SECRETS)
ANTHROPIC_API_KEY=$(kamal secrets extract ANTHROPIC_API_KEY $SECRETS)
GOOGLE_API_KEY=$(kamal secrets extract GOOGLE_API_KEY $SECRETS)
STRIPE_SECRET_KEY=$(kamal secrets extract STRIPE_SECRET_KEY $SECRETS)
STRIPE_WEBHOOK_SECRET=$(kamal secrets extract STRIPE_WEBHOOK_SECRET $SECRETS)

# Compose the DATABASE_URL from components
DATABASE_URL="postgresql+asyncpg://quillcv:${DB_PASSWORD}@quillcv-db:5432/quillcv_production"

# Postgres accessory needs the password directly
POSTGRES_PASSWORD=$DB_PASSWORD


# GitHub Container Registry (ghcr.io) authentication via GitHub CLI
KAMAL_REGISTRY_USERNAME=$(gh api user --jq '.login')
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

