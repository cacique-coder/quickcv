# QuillCV Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# ── Session & JWT ──────────────────────────────────────────────
# Change these in production — any random 32+ char string works.
SESSION_SECRET=quillcv-dev-secret-change-in-prod
JWT_SECRET=quillcv-jwt-dev-secret-change-in-prod

# ── LLM Provider ───────────────────────────────────────────────
# Options: anthropic | openai | gemini
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ── Mailgun (email sending) ─────────────────────────────────────
# US region endpoint: api.mailgun.net
# Get these from https://app.mailgun.com/mg/sending/domains
#
# When SESSION_SECRET is the default dev value (above), emails are logged
# instead of sent — no Mailgun credentials needed for local development.
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── Stripe (payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# ── Cloudflare R2 (photo storage) ──────────────────────────────
# Optional — photos are stored locally if R2 is not configured.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── OAuth (optional) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Encryption ─────────────────────────────────────────────────
# Fernet key for PII vault server-side encryption (OAuth users).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=
